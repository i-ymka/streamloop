---
import DiscordFloating from './DiscordFloating.astro';
const DISCORD_URL = 'https://discord.gg/d5UsBr9y';
---

<!-- Liquid glass SVG filter -->
<svg style="display:none" aria-hidden="true">
  <filter id="glass-distortion" x="-5%" y="-5%" width="110%" height="110%" filterUnits="objectBoundingBox">
    <feTurbulence type="fractalNoise" baseFrequency="0.001 0.005" numOctaves="1" seed="17" result="turbulence"/>
    <feComponentTransfer in="turbulence" result="mapped">
      <feFuncR type="gamma" amplitude="1" exponent="10" offset="0.5"/>
      <feFuncG type="gamma" amplitude="0" exponent="1" offset="0"/>
      <feFuncB type="gamma" amplitude="0" exponent="1" offset="0.5"/>
    </feComponentTransfer>
    <feGaussianBlur in="turbulence" stdDeviation="3" result="softMap"/>
    <feSpecularLighting in="softMap" surfaceScale="5" specularConstant="1" specularExponent="100" lightingColor="white" result="specLight">
      <fePointLight x="-200" y="-200" z="300"/>
    </feSpecularLighting>
    <feComposite in="specLight" operator="arithmetic" k1="0" k2="1" k3="1" k4="0" result="litImage"/>
    <feDisplacementMap in="SourceGraphic" in2="softMap" scale="120" xChannelSelector="R" yChannelSelector="G"/>
  </filter>
</svg>

<section id="discord" class="relative py-16 sm:py-32 px-6">

  <!-- Ambient glow behind card -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="overflow:hidden;">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:400px;background:radial-gradient(ellipse,rgba(145,71,255,0.14) 0%,transparent 70%);border-radius:50%;"></div>
  </div>

  <!-- Three.js 3D floating Discord logos -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="overflow:hidden;">
    <DiscordFloating />
  </div>

  <div class="max-w-2xl mx-auto" style="position:relative;">
    <div class="rounded-2xl p-8 sm:p-12 text-center relative overflow-hidden"
      style="box-shadow:0 6px 6px rgba(0,0,0,0.3),0 0 40px rgba(0,0,0,0.2);">

      <!-- Layer 1: liquid glass distortion + blur -->
      <div class="absolute inset-0 z-0 rounded-2xl overflow-hidden" style="backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px);filter:url(#glass-distortion);isolation:isolate;"></div>
      <!-- Layer 2: purple tint -->
      <div class="absolute inset-0 z-10 rounded-2xl" style="background:rgba(145,71,255,0.12);"></div>
      <!-- Layer 3: inner highlight (top edge = light reflection) -->
      <div class="absolute inset-0 z-20 rounded-2xl" style="box-shadow:inset 2px 2px 1px 0 rgba(255,255,255,0.18),inset -1px -1px 1px 1px rgba(145,71,255,0.2);"></div>

      <!-- Inner glow -->
      <div class="absolute inset-0 pointer-events-none z-20"
        style="background:radial-gradient(ellipse 70% 50% at 50% 110%,rgba(145,71,255,0.15),transparent);">
      </div>

      <div class="relative z-10">
        <!-- Icon -->
        <div class="flex items-center justify-center mb-5">
          <div style="width:48px;height:48px;border-radius:14px;background:rgba(145,71,255,0.15);border:1px solid rgba(145,71,255,0.3);display:flex;align-items:center;justify-content:center;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9147ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
          </div>
        </div>

        <h2 class="text-2xl sm:text-3xl font-bold mb-3" style="color:#efeff1;">
          Join the community
        </h2>
        <p class="text-sm sm:text-base mb-8 max-w-md mx-auto" style="color:#adadb8;">
          A small Discord for people who want to stream but feel stuck.
          No gatekeeping. No "just be yourself" advice. Real challenges, real feedback.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8">
          <div class="flex items-center gap-2 text-sm" style="color:#adadb8;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9147ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Share your wins</span>
          </div>
          <div class="flex items-center gap-2 text-sm" style="color:#adadb8;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9147ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
            <span>See everyone's challenges</span>
          </div>
          <div class="flex items-center gap-2 text-sm" style="color:#adadb8;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9147ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <span>Post your stats</span>
          </div>
        </div>

        <p class="mb-6 text-sm" style="color:#6b6b7b;">Lurking is completely fine. No intro required.</p>

        <a
          href={DISCORD_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-sm transition-all hover:opacity-90 active:scale-95"
          style="background:#9147ff;color:#fff;"
        >
          <svg width="18" height="14" viewBox="0 0 18 14" fill="currentColor" aria-hidden="true">
            <path d="M15.246 1.18A14.831 14.831 0 0 0 11.458 0a.055.055 0 0 0-.059.028c-.164.29-.346.67-.473.967a13.698 13.698 0 0 0-4.11 0A9.972 9.972 0 0 0 6.34.028.057.057 0 0 0 6.28 0 14.79 14.79 0 0 0 2.49 1.18a.052.052 0 0 0-.024.02C.361 4.32-.216 7.376.067 10.393a.062.062 0 0 0 .024.042 14.9 14.9 0 0 0 4.494 2.272.057.057 0 0 0 .062-.02c.346-.473.654-.972.919-1.495a.056.056 0 0 0-.03-.078 9.82 9.82 0 0 1-1.404-.668.057.057 0 0 1-.006-.094c.094-.07.189-.144.279-.218a.055.055 0 0 1 .057-.008c2.946 1.345 6.137 1.345 9.048 0a.055.055 0 0 1 .058.007c.09.075.185.149.28.22a.057.057 0 0 1-.005.093 9.228 9.228 0 0 1-1.405.667.057.057 0 0 0-.03.079c.27.522.578 1.02.918 1.494a.056.056 0 0 0 .062.021 14.856 14.856 0 0 0 4.503-2.272.057.057 0 0 0 .024-.04c.334-3.46-.56-6.49-2.37-9.193a.046.046 0 0 0-.023-.021ZM6.013 8.52c-.886 0-1.617-.814-1.617-1.813 0-1 .717-1.814 1.617-1.814.906 0 1.63.821 1.617 1.814 0 .999-.717 1.813-1.617 1.813Zm5.975 0c-.886 0-1.617-.814-1.617-1.813 0-1 .717-1.814 1.617-1.814.906 0 1.63.821 1.617 1.814 0 .999-.71 1.813-1.617 1.813Z"/>
          </svg>
          Join Discord
        </a>
      </div>
    </div>
  </div>
</section>
