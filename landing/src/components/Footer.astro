---
const DISCORD_URL = 'REPLACE_WITH_DISCORD_INVITE_URL';
---

<footer class="py-10 px-6 border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <span class="font-bold text-sm" style="color:#efeff1;">StreamLoop</span>
      <span class="text-xs" style="color:#6b6b7b;">© 2026</span>
    </div>
    <div class="flex items-center gap-6">
      <a href={DISCORD_URL} target="_blank" rel="noopener noreferrer"
        class="text-xs transition-colors hover:text-white" style="color:#6b6b7b;">
        Discord
      </a>
      <span class="text-xs" style="color:#3d3d4d;">Made for streamers who feel stuck</span>
    </div>
  </div>
</footer>
