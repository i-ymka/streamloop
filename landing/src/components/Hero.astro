---
// Hero — adapted from 21st.dev "Gradient Bar Hero Section"
// Source: gradient-bar-hero-section by 21st.dev
// Changes: purple bars instead of orange, Astro (no React), custom copy, Google Sheets form
---

<section class="relative min-h-screen w-full flex flex-col items-center justify-center px-6 overflow-x-hidden">

  <!-- Gradient bars — original position -->
  <div class="hero-bars absolute bottom-0 left-0 right-0 h-64 flex items-end pointer-events-none" aria-hidden="true">
    {Array.from({length: 20}).map((_, i) => {
      const pos = i / 19;
      const dist = Math.abs(pos - 0.5) * 2;
      const h = 30 + 70 * Math.pow(dist, 1.3);
      const delay = (i * 0.08).toFixed(2);
      return (
        <div
          style={`flex:1;height:${h}%;background:linear-gradient(to top,#9147ff,transparent);opacity:0.35;animation:pulseBar 2s ease-in-out ${delay}s infinite alternate;`}
        />
      );
    })}
  </div>

  <!-- Radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
    style="background:radial-gradient(ellipse 70% 50% at 50% 80%,rgba(145,71,255,0.18) 0%,transparent 70%);">
  </div>



  <!-- Content -->
  <div class="relative z-10 w-full max-w-3xl mx-auto text-center flex flex-col items-center gap-8">

    <!-- Badge -->
    <div class="fade-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm"
      style="background:rgba(145,71,255,0.12);border:1px solid rgba(145,71,255,0.3);color:#c4a4ff;">
      <span class="w-1.5 h-1.5 rounded-full bg-[#9147ff] inline-block"></span>
      Early access — join the waitlist
    </div>

    <!-- Headline -->
    <h1 class="fade-up delay-100 text-5xl sm:text-6xl md:text-7xl font-bold leading-[1.05] tracking-tight" style="color:#efeff1;">
      You stream.<br/>
      <span style="color:#9147ff;">We improve.</span><br/>
      Repeat.
    </h1>

    <!-- Subheadline -->
    <p class="fade-up delay-250 text-lg sm:text-xl max-w-xl leading-relaxed" style="color:#adadb8;">
      You're putting in the streams. The chat is empty. The analytics make no sense. StreamLoop gives you one specific thing to fix — every single stream.
    </p>

    <!-- Form -->
    <form
      id="waitlist-form"
      class="fade-up delay-400 w-full max-w-md flex flex-col sm:flex-row gap-3"
      novalidate
    >
      <input
        id="email-input"
        type="email"
        placeholder="your@email.com"
        autocomplete="email"
        required
        class="flex-1 px-5 py-3.5 rounded-xl text-sm outline-none transition-all"
        style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#efeff1;caret-color:#9147ff;"
        onfocus="this.style.borderColor='rgba(145,71,255,0.6)'"
        onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
      />
      <button
        type="submit"
        id="submit-btn"
        class="px-6 py-3.5 rounded-xl text-sm font-semibold transition-all hover:opacity-90 active:scale-95 whitespace-nowrap"
        style="background:#9147ff;color:#fff;"
      >
        Get my first challenge
      </button>
    </form>

    <!-- Micro-copy -->
    <p class="fade-up delay-400 text-xs" style="color:#6b6b7b;margin-top:-16px;">
      No spam. No pressure. We're also introverts.
    </p>

    <!-- Form error/success messages -->
    <p id="form-error" class="hidden text-sm" style="color:#f87171;">Please enter a valid email.</p>
    <div id="form-success" class="hidden fade-up rounded-xl px-6 py-4 text-sm text-center"
      style="background:rgba(145,71,255,0.15);border:1px solid rgba(145,71,255,0.3);color:#c4a4ff;">
      <svg style="display:inline;vertical-align:-3px;margin-right:5px;" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#c4a4ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>You're on the list! Check <a href="https://discord.gg/d5UsBr9y" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2">our Discord</a> for the community.
    </div>

    <!-- Social proof counter -->
    <div id="social-proof" class="fade-up delay-550 flex items-center gap-2 text-xs" style="color:#6b6b7b;">
      <span class="pulse-dot w-1.5 h-1.5 rounded-full inline-block" style="background:#9147ff;opacity:0.7;"></span>
      <span id="social-proof-text">Early access · Limited spots</span>
    </div>

    <!-- Marquee -->
    <div class="fade-up delay-550 w-full overflow-hidden" style="mask-image:linear-gradient(to right,transparent,black 15%,black 85%,transparent);">
      <div class="marquee-track gap-8 text-xs" style="color:#6b6b7b;">
        {['r/Twitch', 'r/streaming', 'r/letsplay', 'r/contentcreators', 'Twitch Creator Camp', 'r/juststart', 'r/Twitch', 'r/streaming', 'r/letsplay', 'r/contentcreators', 'Twitch Creator Camp', 'r/juststart'].map(t => (
          <span class="flex items-center gap-2 whitespace-nowrap">
            <span class="w-1 h-1 rounded-full inline-block" style="background:#9147ff;"></span>
            {t}
          </span>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzfUYcflfSDcnQa04wpyn5-1JpR5uZwYoxZyqvKwcW3-lEgf1rI7pEV59BPEf87oO8S/exec';

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const input = document.getElementById('email-input') as HTMLInputElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const error = document.getElementById('form-error')!;
  const success = document.getElementById('form-success')!;

  // Dynamic waitlist counter
  (async () => {
    try {
      const res = await fetch(SCRIPT_URL + '?action=count', { mode: 'cors' });
      if (!res.ok) return;
      const data = await res.json();
      const count = typeof data.count === 'number' ? data.count : null;
      if (count !== null && count >= 10) {
        const el = document.getElementById('social-proof-text');
        if (el) el.textContent = `${count} streamers already in`;
      }
    } catch {
      // silent fallback — default text stays
    }
  })();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    error.classList.add('hidden');

    const email = input.value.trim();
    if (!email || !email.includes('@') || !email.includes('.')) {
      error.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Joining...';

    try {
      await fetch(SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      form.classList.add('hidden');
      success.classList.remove('hidden');
    } catch {
      btn.disabled = false;
      btn.textContent = 'Get my first challenge';
      error.textContent = 'Something went wrong. Try again.';
      error.classList.remove('hidden');
    }
  });
</script>

<style>
  @keyframes pulseDot {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.45); }
  }
  .pulse-dot {
    animation: pulseDot 2s ease-in-out infinite;
  }

  @media (max-width: 1023px) {
    .hero-bars > div:nth-child(5n) { display: none; }
  }
  @media (max-width: 639px) {
    .hero-bars > div:nth-child(3n) { display: none; }
  }
</style>
