<style>
  /* ── Section design tokens ── */
  :root {
    --sl-bg: hsl(258 60% 5%);
    --sl-surface: hsl(258 40% 11%);
    --sl-border: hsl(258 35% 18%);
    --sl-purple: hsl(263 69% 56%);
    --sl-purple-dim: hsl(263 69% 56% / 0.12);
    --sl-text: hsl(213 31% 95%);
    --sl-muted: hsl(220 10% 68%);
    --sl-label: hsl(220 10% 43%);
  }

  /* ── App screen design tokens (Gaming palette — HSL) ── */
  #sl-screens {
    --app-bg:     hsl(240 55% 6%);
    --app-card:   hsl(244 43% 13%);
    --app-nav:    hsl(243 50% 5%);
    --app-border: hsl(263 42% 20% / 0.7);
    --app-text:   hsl(213 31% 95%);
    --app-muted:  hsl(215 20% 65%);
    --app-label:  hsl(220 15% 38%);
  }

  /* ── Layout ── */
  .sl-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .sl-header {
    text-align: center;
    margin-bottom: 0;
    padding-bottom: 40px;
  }
  @media (min-width: 768px) {
    .sl-header { padding-bottom: 64px; }
  }
  .sl-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sl-purple);
    margin: 0 0 12px;
  }
  .sl-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--sl-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .sl-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    color: var(--sl-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Body: steps + phone ── */
  .sl-body {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 32px;
    padding-top: 40px;
  }
  @media (min-width: 768px) {
    .sl-body { padding-top: 64px; }
  }
  @media (min-width: 1024px) {
    .sl-body {
      flex-direction: row;
      align-items: center;
      gap: 64px;
    }
  }

  /* ── Steps ── */
  .sl-steps {
    display: none;
  }
  @media (min-width: 1024px) {
    .sl-steps {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
    }
  }

  .sl-step {
    display: flex;
    gap: 20px;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid hsl(258 35% 16%);
    background: hsl(258 40% 7%);
    cursor: pointer;
    text-align: left;
    transition: background 200ms ease, border-color 200ms ease;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .sl-step { padding: 20px; border-radius: 16px; }
  }
  .sl-step:hover {
    background: hsl(263 69% 56% / 0.08);
    border-color: hsl(263 69% 56% / 0.25);
  }
  .sl-step--active {
    background: var(--sl-purple-dim);
    border-color: hsl(263 69% 56% / 0.4);
  }

  .sl-step__num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1px;
    color: var(--sl-purple);
    opacity: 0.45;
    flex-shrink: 0;
    padding-top: 2px;
    min-width: 24px;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__num { opacity: 1; }

  .sl-step__content { flex: 1; min-width: 0; }

  .sl-step__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0;
  }
  @media (min-width: 1024px) {
    .sl-step__header { gap: 10px; margin-bottom: 8px; }
  }
  .sl-step__icon {
    width: 18px;
    height: 18px;
    color: var(--sl-purple);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__icon { opacity: 1; }

  .sl-step__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-text);
    margin: 0;
    line-height: 1.3;
  }
  @media (min-width: 1024px) {
    .sl-step__title { font-size: 15px; }
  }

  .sl-step__desc {
    display: none;
  }
  @media (min-width: 1024px) {
    .sl-step__desc {
      display: block;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      color: var(--sl-muted);
      line-height: 1.6;
      margin: 0 0 10px;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 250ms ease, opacity 250ms ease, margin 250ms ease;
    }
    .sl-step--active .sl-step__desc {
      max-height: 160px;
      opacity: 1;
    }
  }

  .sl-step__bullets {
    display: none;
  }
  @media (min-width: 1024px) {
    .sl-step__bullets {
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      flex-direction: column;
      gap: 6px;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 250ms ease, opacity 250ms ease;
    }
    .sl-step--active .sl-step__bullets {
      max-height: 120px;
      opacity: 1;
    }
  }
  .sl-step__bullets li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: var(--sl-label);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }
  .sl-step__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sl-purple);
    opacity: 0.6;
  }

  /* ── Phone ── */
  .sl-phone-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sl-phone-frame {
    width: 270px;
  }

  /* ── Scrollbar hide ── */
  #sl-screens * {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #sl-screens *::-webkit-scrollbar { display: none; }

  /* ── Screen transition ── */
  .sl-screen {
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .sl-screen--entering {
    opacity: 0;
    transform: translateY(8px);
  }
  .sl-screen--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Blur bar ── */
  #sl-screens .sl-screen::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 36px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 6, 20, 0.6);
    pointer-events: none;
  }
</style>

<script>
  // iOS: CSS filter:url on HTML broken (WebKit bug #261806) — show clean mirror
  (function () {
    var isIOS = /iPhone|iPad|iPod/.test(navigator.userAgent);
    if (!isIOS) return;

    // 1. Remove broken CSS filter on mirror (in HowItWorksHeader)
    var mirror = document.getElementById('sl-bars-html');
    if (mirror) mirror.style.filter = 'none';

    // 2. Discord-style glass on phone wrap
    var phoneWrap = document.querySelector('.sl-phone-wrap');
    if (phoneWrap) {
      var glow = document.createElement('div');
      glow.style.cssText = [
        'position:absolute',
        'inset:-40px -60px',
        'background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(145,71,255,0.35) 0%,transparent 70%)',
        'pointer-events:none',
        'z-index:0',
        'border-radius:50%',
      ].join(';');
      phoneWrap.style.position = 'relative';
      phoneWrap.insertBefore(glow, phoneWrap.firstChild);

      phoneWrap.style.cssText += [
        'background:rgba(12,9,28,0.5)',
        '-webkit-backdrop-filter:blur(16px) saturate(160%)',
        'backdrop-filter:blur(16px) saturate(160%)',
        'box-shadow:inset 0 1px 0 rgba(255,255,255,0.12),inset 0 -1px 0 rgba(145,71,255,0.08),0 8px 32px rgba(0,0,0,0.4)',
        'border-radius:32px',
        'padding:20px 12px',
      ].join(';');
    }

    // 3. Gyroscope 3D parallax
    if (!window.DeviceOrientationEvent) return;

    var section = document.getElementById('how-it-works');
    var phoneEl = document.querySelector('.sl-phone-wrap');
    var header  = document.querySelector('.sl-header');

    function handleOrientation(e) {
      var gamma = e.gamma || 0;
      var beta  = (e.beta || 0) - 30;

      gamma = Math.max(-25, Math.min(25, gamma));
      beta  = Math.max(-20, Math.min(20, beta));

      if (phoneEl) phoneEl.style.transform = 'translateX(' + (gamma * 0.6) + 'px) translateY(' + (beta * 0.3) + 'px)';
      if (header)  header.style.transform  = 'translateX(' + (gamma * 0.25) + 'px) translateY(' + (beta * 0.12) + 'px)';
      if (mirror)  mirror.style.transform  = 'translateX(' + (gamma * 0.08) + 'px)';
    }

    if (typeof DeviceOrientationEvent.requestPermission === 'function') {
      document.addEventListener('touchstart', function askPermission() {
        DeviceOrientationEvent.requestPermission()
          .then(function(state) {
            if (state === 'granted') {
              window.addEventListener('deviceorientation', handleOrientation);
            }
          });
        document.removeEventListener('touchstart', askPermission);
      }, { once: true });
    } else {
      window.addEventListener('deviceorientation', handleOrientation);
    }
  })();
</script>

<script>
  (function () {
    var steps   = document.querySelectorAll('.sl-step');
    var screens = document.querySelectorAll('#sl-screens .sl-screen');
    var navItems = document.querySelectorAll('#sl-screens .sl-nav-item');
    var current = 0;

    var stepData = [
      { label: '01 / 04', title: 'Get your challenge', subtitle: 'One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.' },
      { label: '02 / 04', title: 'Stream & upload', subtitle: 'Go live, do your thing, then screenshot your stats. The AI reads the numbers — you don\'t type anything.' },
      { label: '03 / 04', title: 'See what worked', subtitle: 'Not "stream more consistently." The AI tells you what broke this stream, what worked, and what\'s next.' },
      { label: '04 / 04', title: 'Track your journey', subtitle: 'See where you started, where you are, and what\'s ahead. Levels, streaks, XP — your whole arc in one place.' },
    ];
    var isMobile = function() { return window.innerWidth < 1024; };

    var elLabel    = document.getElementById('sl-label');
    var elTitle    = document.getElementById('sl-title');
    var elSubtitle = document.getElementById('sl-subtitle');

    function goTo(index) {
      if (index === current && screens[index].style.display === 'flex') return;
      current = index;

      steps.forEach(function (s, i) {
        s.classList.toggle('sl-step--active', i === index);
      });

      if (isMobile() && stepData[index]) {
        if (elLabel)    elLabel.textContent    = stepData[index].label;
        if (elTitle)    elTitle.textContent    = stepData[index].title;
        if (elSubtitle) elSubtitle.textContent = stepData[index].subtitle;
      }

      navItems.forEach(function (nav) {
        var parent = nav.parentElement;
        var siblings = Array.prototype.slice.call(parent.querySelectorAll('.sl-nav-item'));
        var pos = siblings.indexOf(nav);
        var icon = nav.querySelector('svg');
        var label = nav.querySelector('span');
        var isActive = pos === index;
        nav.classList.toggle('sl-nav-active', isActive);
        if (icon) icon.setAttribute('stroke', isActive ? '#A78BFA' : 'var(--app-label, #4A4A6A)');
        if (label) {
          label.style.color = isActive ? '#A78BFA' : '';
          label.style.fontWeight = isActive ? '700' : '';
        }
        nav.style.background = isActive ? 'rgba(124,58,237,0.12)' : '';
        nav.style.borderRadius = isActive ? '10px' : '';
      });

      screens.forEach(function (s, i) {
        if (i === index) {
          s.style.display = 'flex';
          s.classList.add('sl-screen--entering');
          s.classList.remove('sl-screen--visible');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              s.classList.remove('sl-screen--entering');
              s.classList.add('sl-screen--visible');
            });
          });
        } else {
          s.style.display = 'none';
          s.classList.remove('sl-screen--visible', 'sl-screen--entering');
        }
      });
    }

    steps.forEach(function (step, i) {
      step.addEventListener('click', function () { goTo(i); });
    });

    navItems.forEach(function (nav) {
      nav.style.cursor = 'pointer';
      nav.addEventListener('click', function (e) {
        e.stopPropagation();
        var parent = nav.parentElement;
        var siblings = parent.querySelectorAll('.sl-nav-item');
        var idx = Array.prototype.indexOf.call(siblings, nav);
        if (idx >= 0 && idx < screens.length) goTo(idx);
      });
    });
  })();
</script>
