---
// HowItWorksPhone — interactive steps + phone mockup
// Split from HowItWorksPreview.astro
---

<section style="position:relative;padding:0 20px 64px;">
  <div class="sl-container" style="position:relative;z-index:3;">

    <!-- Header -->
    <div class="sl-header">
      <p class="sl-label" id="sl-label">The Loop</p>
      <h2 class="sl-title" id="sl-title">Four steps. Every stream. Forever.</h2>
      <p class="sl-subtitle" id="sl-subtitle">No courses. No fluff. One challenge, one stream, one honest verdict — then repeat.</p>
    </div>

    <!-- Body: steps + phone -->
    <div class="sl-body">

      <!-- Steps (left on desktop, top on mobile) -->
      <div class="sl-steps">

        <button class="sl-step sl-step--active" data-screen="0">
          <div class="sl-step__num">01</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
              <h3 class="sl-step__title">Get your challenge</h3>
            </div>
            <p class="sl-step__desc">One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.</p>
            <ul class="sl-step__bullets">
              <li>Personalised to where you actually are</li>
              <li>Based on your weak spots, not generic advice</li>
              <li>Takes 5 seconds to read, one stream to do</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="1">
          <div class="sl-step__num">02</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
              </svg>
              <h3 class="sl-step__title">Stream & upload</h3>
            </div>
            <p class="sl-step__desc">Go live, do your thing, then screenshot your stats. Drop it in — the AI reads the numbers, you don't type anything.</p>
            <ul class="sl-step__bullets">
              <li>Twitch, YouTube, Kick, TikTok — any platform</li>
              <li>Just a screenshot — no API, no OAuth</li>
              <li>Done in under 30 seconds</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="2">
          <div class="sl-step__num">03</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
              <h3 class="sl-step__title">See what worked</h3>
            </div>
            <p class="sl-step__desc">Not "stream more consistently." The AI tells you what broke this stream, what worked, and what your next challenge is.</p>
            <ul class="sl-step__bullets">
              <li>Specific to your numbers, not generic tips</li>
              <li>What went well, what to fix</li>
              <li>Next challenge unlocks automatically</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="3">
          <div class="sl-step__num">04</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
              <h3 class="sl-step__title">Track your journey</h3>
            </div>
            <p class="sl-step__desc">See where you started, where you are, and what's ahead. Levels, streaks, XP — your whole arc in one place.</p>
            <ul class="sl-step__bullets">
              <li>Levels from "Streaming into the void" to "You made it"</li>
              <li>Weekly streak keeps you consistent</li>
              <li>Watch yourself grow over months</li>
            </ul>
          </div>
        </button>

      </div>

      <!-- Phone mockup (right on desktop, bottom on mobile) -->
      <div class="sl-phone-wrap">
        <div class="sl-phone-frame">
          <iphone-16-max mode="dark">
            <div id="sl-screens" style="width:100%;height:100%;position:relative;overflow:hidden;background:hsl(240 55% 6%);font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;">

              <!-- ── Screen 0: Home ── -->
              <div class="sl-screen" data-screen="0" style="position:absolute;inset:0;display:flex;flex-direction:column;background:var(--app-bg);">
                <div style="flex:1;overflow-y:auto;padding:36px 14px 10px;display:flex;flex-direction:column;gap:10px;">

                  <!-- Header row -->
                  <div style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                      <h2 style="font-size:19px;font-weight:800;color:var(--app-text);margin:0;letter-spacing:-0.3px;">Hey, Marcus</h2>
                      <p style="font-size:10px;color:var(--app-muted);margin:3px 0 0;letter-spacing:0.3px;">Week 4 of your journey</p>
                    </div>
                    <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#7C3AED,#A78BFA);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 0 2px rgba(124,58,237,0.3);">
                      <span style="font-size:13px;font-weight:800;color:white;">M</span>
                    </div>
                  </div>

                  <!-- Stats row -->
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                    <!-- Streak card -->
                    <div style="background:var(--app-card);border:1px solid var(--app-border);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:6px;">
                      <div style="width:28px;height:28px;border-radius:8px;background:rgba(251,146,60,0.15);display:flex;align-items:center;justify-content:center;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FB923C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>
                      </div>
                      <p style="font-size:24px;font-weight:800;color:var(--app-text);margin:0;line-height:1;letter-spacing:-0.5px;">4</p>
                      <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-muted);margin:0;text-transform:uppercase;">Week streak</p>
                    </div>
                    <!-- Level card -->
                    <div style="background:var(--app-card);border:1px solid var(--app-border);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:6px;">
                      <div style="width:28px;height:28px;border-radius:8px;background:rgba(124,58,237,0.15);display:flex;align-items:center;justify-content:center;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      </div>
                      <p style="font-size:18px;font-weight:800;color:var(--app-text);margin:0;line-height:1.1;letter-spacing:-0.3px;">Lvl 2</p>
                      <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-muted);margin:0;text-transform:uppercase;">Someone's watching</p>
                    </div>
                  </div>

                  <!-- Level progress -->
                  <div style="background:var(--app-card);border:1px solid var(--app-border);border-radius:14px;padding:12px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                      <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-muted);margin:0;text-transform:uppercase;">Level progress</p>
                      <span style="font-size:10px;font-weight:700;color:#A78BFA;background:rgba(124,58,237,0.12);padding:2px 8px;border-radius:20px;">62%</span>
                    </div>
                    <div style="height:5px;background:rgba(42,32,64,0.8);border-radius:3px;overflow:hidden;">
                      <div style="width:62%;height:100%;background:linear-gradient(90deg,#7C3AED,#A78BFA);border-radius:3px;"></div>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-top:6px;">
                      <p style="font-size:10px;color:#A78BFA;margin:0;font-weight:500;">Someone's watching</p>
                      <p style="font-size:10px;color:var(--app-label);margin:0;">Small circle →</p>
                    </div>
                  </div>

                  <!-- Challenge label -->
                  <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-label);margin:0;text-transform:uppercase;">Your challenge</p>

                  <!-- Challenge card -->
                  <div style="background:var(--app-card);border:1px solid rgba(124,58,237,0.35);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:8px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <span style="background:rgba(124,58,237,0.18);color:#A78BFA;font-size:9px;font-weight:700;padding:3px 8px;border-radius:6px;letter-spacing:0.8px;border:1px solid rgba(124,58,237,0.3);">ACTIVE</span>
                      <span style="font-size:10px;color:var(--app-label);">Stream #12</span>
                    </div>
                    <p style="font-size:13px;font-weight:700;color:var(--app-text);line-height:1.4;margin:0;">Go live for 60 min without checking your viewer count</p>
                    <p style="font-size:11px;color:var(--app-muted);line-height:1.5;margin:0;">Anxiety-checking mid-stream tanks your energy. Your audience can feel it.</p>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <div style="display:flex;align-items:center;gap:4px;">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span style="font-size:10px;color:var(--app-label);">Ends Sunday</span>
                      </div>
                      <span style="font-size:10px;font-weight:700;color:#FBBF24;background:rgba(251,191,36,0.1);padding:2px 7px;border-radius:6px;">+150 XP</span>
                    </div>
                    <div style="background:linear-gradient(135deg,#7C3AED,#6D28D9);border-radius:10px;padding:9px;text-align:center;box-shadow:0 4px 12px rgba(124,58,237,0.3);">
                      <span style="font-size:12px;font-weight:700;color:white;letter-spacing:0.2px;">Mark as Complete</span>
                    </div>
                  </div>

                </div>
                <!-- Nav bar -->
                <div style="flex-shrink:0;height:56px;background:var(--app-nav);border-top:1px solid var(--app-border);display:flex;align-items:center;padding:0 4px;">
                  <div class="sl-nav-item sl-nav-active" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;border-radius:10px;background:rgba(124,58,237,0.12);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg>
                    <span style="font-size:9px;color:#A78BFA;font-weight:700;">Home</span>
                  </div>
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Upload</span>
                  </div>
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Analysis</span>
                  </div>
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Progress</span>
                  </div>
                </div>
              </div>

              <!-- ── Screen 1: Upload ── -->
              <div class="sl-screen" data-screen="1" style="position:absolute;inset:0;display:none;flex-direction:column;background:var(--app-bg);">
                <div style="flex:1;overflow-y:auto;padding:36px 14px 10px;display:flex;flex-direction:column;gap:10px;">

                  <!-- Header -->
                  <div>
                    <p style="font-size:19px;font-weight:800;color:var(--app-text);margin:0;letter-spacing:-0.3px;">Upload recap</p>
                    <p style="font-size:10px;color:var(--app-muted);margin:4px 0 0;">Stream #12 · Just finished</p>
                  </div>

                  <!-- Platform selector -->
                  <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-label);margin:0;text-transform:uppercase;">Platform</p>
                  <div style="display:flex;gap:6px;">
                    <span style="background:rgba(124,58,237,0.15);border:1.5px solid rgba(124,58,237,0.5);color:#A78BFA;font-size:11px;font-weight:700;padding:6px 12px;border-radius:10px;letter-spacing:0.2px;">Twitch</span>
                    <span style="background:var(--app-card);border:1px solid var(--app-border);color:var(--app-label);font-size:11px;padding:6px 12px;border-radius:10px;">YouTube</span>
                    <span style="background:var(--app-card);border:1px solid var(--app-border);color:var(--app-label);font-size:11px;padding:6px 12px;border-radius:10px;">Kick</span>
                  </div>

                  <!-- Upload zone label -->
                  <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-label);margin:0;text-transform:uppercase;">Analytics screenshot</p>

                  <!-- Drop zone -->
                  <div style="border:1.5px dashed rgba(124,58,237,0.25);border-radius:14px;padding:22px 14px;display:flex;flex-direction:column;align-items:center;gap:8px;background:rgba(124,58,237,0.04);">
                    <div style="width:44px;height:44px;border-radius:12px;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);display:flex;align-items:center;justify-content:center;">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                    </div>
                    <p style="font-size:12px;font-weight:600;color:var(--app-muted);margin:0;">Drop your screenshot here</p>
                    <p style="font-size:10px;color:var(--app-label);margin:0;">or tap to browse from Photos</p>
                    <p style="font-size:9px;color:var(--app-label);margin:0;opacity:0.7;">PNG, JPG · Max 10MB</p>
                  </div>

                  <!-- What to capture -->
                  <p style="font-size:9px;font-weight:700;letter-spacing:1.2px;color:var(--app-label);margin:0;text-transform:uppercase;">What to capture</p>
                  <div style="background:var(--app-card);border:1px solid var(--app-border);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:8px;">
                    <div style="display:flex;align-items:center;gap:8px;">
                      <div style="width:20px;height:20px;border-radius:6px;background:rgba(124,58,237,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                      </div>
                      <p style="font-size:10px;color:var(--app-muted);margin:0;line-height:1.4;">Peak viewers, avg viewers, duration</p>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                      <div style="width:20px;height:20px;border-radius:6px;background:rgba(124,58,237,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                      </div>
                      <p style="font-size:10px;color:var(--app-muted);margin:0;line-height:1.4;">Follower/subscriber growth</p>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;">
                      <div style="width:20px;height:20px;border-radius:6px;background:rgba(124,58,237,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                      </div>
                      <p style="font-size:10px;color:var(--app-muted);margin:0;line-height:1.4;">Chat activity or engagement</p>
                    </div>
                  </div>

                  <!-- CTA disabled -->
                  <div style="background:var(--app-card);border:1px solid var(--app-border);border-radius:12px;padding:11px;text-align:center;opacity:0.5;">
                    <span style="font-size:12px;font-weight:700;color:var(--app-label);">Upload a screenshot first</span>
                  </div>

                </div>
                <!-- Nav bar -->
                <div style="flex-shrink:0;height:56px;background:var(--app-nav);border-top:1px solid var(--app-border);display:flex;align-items:center;padding:0 4px;">
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Home</span>
                  </div>
                  <div class="sl-nav-item sl-nav-active" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;border-radius:10px;background:rgba(124,58,237,0.12);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                    <span style="font-size:9px;color:#A78BFA;font-weight:700;">Upload</span>
                  </div>
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Analysis</span>
                  </div>
                  <div class="sl-nav-item" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--app-label)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg>
                    <span style="font-size:9px;color:var(--app-label);">Progress</span>
                  </div>
                </div>
              </div>

              <!-- ── Screen 2: Analysis ── -->
              <div class="sl-screen" data-screen="2" style="position:absolute;inset:0;display:none;flex-direction:column;background:var(--app-bg);">
                <div style="flex:1;overflow-y:auto;padding:36px 14px 10px;display:flex;flex-direction:column;gap:10px;">

                  <!-- Header -->
                  <div>
                    <p style="font-size:19px;font-weight:800;color:var(--app-text);margin:0;letter-spacing:-0.3px;">Stream analysis</p>
                    <p style="font-size:10px;color:var(--app-label);margin:4px 0 0;letter-spacing:0.5px;text-transform:uppercase;">Stream #11 · Twitch · Nov 12</p>
                  </div>

                  <!-- Stream title -->
