      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 250ms ease, opacity 250ms ease, margin 250ms ease;
    }
    .sl-step--active .sl-step__desc {
      max-height: 160px;
      opacity: 1;
    }
  }

  .sl-step__bullets {
    display: none;
  }
  @media (min-width: 1024px) {
    .sl-step__bullets {
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      flex-direction: column;
      gap: 6px;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 250ms ease, opacity 250ms ease;
    }
    .sl-step--active .sl-step__bullets {
      max-height: 120px;
      opacity: 1;
    }
  }
  .sl-step__bullets li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: var(--sl-label);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }
  .sl-step__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sl-purple);
    opacity: 0.6;
  }

  /* ── Step left-edge progress bar ── */
  .sl-step {
    position: relative;
  }
  .sl-step::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: rgba(145, 71, 255, 0.15);
    border-radius: 2px;
  }
  .sl-step::after {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 2px;
    height: 0%;
    background: #9147ff;
    border-radius: 2px;
    transition: height 0.4s ease;
  }
  .sl-step--active::after {
    height: calc(100% - 24px);
  }

  /* ── Phone ── */
  .sl-phone-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    transform: scale(0.88) translateY(32px);
    filter: blur(6px);
    transition: opacity 0.8s cubic-bezier(0.34, 1.56, 0.64, 1),
                transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1),
                filter 0.6s ease;
  }
  .sl-phone-wrap.is-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: blur(0px);
  }
  @media (prefers-reduced-motion: reduce) {
    .sl-phone-wrap {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
  .sl-phone-frame {
    width: 270px;
  }

  /* ── Responsive bar count — fewer bars on smaller screens ── */
  @media (max-width: 1023px) {
    .sl-mirror-bars > div:nth-child(5n) { display: none; }
  }
  @media (max-width: 639px) {
    .sl-mirror-bars > div:nth-child(3n) { display: none; }
  }

  /* ── Scrollbar hide ── */
  #sl-screens * {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #sl-screens *::-webkit-scrollbar { display: none; }

  /* ── Screen transition ── */
  .sl-screen {
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .sl-screen--entering {
    opacity: 0;
    transform: translateY(8px);
  }
  .sl-screen--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Nav hint CSS moved to global.css — JS-created elements don't get Astro scoping */

  /* ── Repeat CTA ── */
  .sl-repeat-cta {
    text-align: center;
    padding: 80px 20px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .sl-repeat-cta__label {
    color: #adadb8;
    font-size: 1rem;
