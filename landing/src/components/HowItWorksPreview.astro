    opacity: 0.6;
  }

  /* ── Phone ── */
  .sl-phone-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sl-phone-frame {
    width: 270px;
  }

  /* ── Responsive bar count — fewer bars on smaller screens ── */
  @media (max-width: 1023px) {
    .sl-mirror-bars > div:nth-child(5n) { display: none; }
  }
  @media (max-width: 639px) {
    .sl-mirror-bars > div:nth-child(3n) { display: none; }
  }

  /* ── Edge bleed for displacement filter — provides pixels at edges ── */
  .sl-mirror-bars::before,
  .sl-mirror-bars::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30px;
    background: linear-gradient(to top, #9147ff, transparent);
    opacity: 0.35;
    animation: pulseBar 2s ease-in-out infinite alternate;
  }
  .sl-mirror-bars::before { left: -30px; animation-delay: 0s; }
  .sl-mirror-bars::after { right: -30px; animation-delay: 1.52s; }

  /* ── Scrollbar hide ── */
  #sl-screens * {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #sl-screens *::-webkit-scrollbar { display: none; }

  /* ── Screen transition ── */
  .sl-screen {
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .sl-screen--entering {
    opacity: 0;
    transform: translateY(8px);
  }
  .sl-screen--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Blur bar ── */
  #sl-screens .sl-screen::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 36px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 6, 20, 0.6);
    pointer-events: none;
  }
</style>

<script>
  // iOS water canvas — pixel displacement, replaces SVG filter (WebKit bug #261806)
  (function () {
    var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
      (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
    if (!isIOS) return;

    var svgDiv = document.getElementById('sl-bars-svg');
    var canvas = document.getElementById('sl-water-canvas');
    if (!svgDiv || !canvas) return;

    svgDiv.style.display = 'none';
    canvas.style.display = 'block';

    var ctx = canvas.getContext('2d');
    var N   = 20;
    var H   = 271;
    var t   = 0;

    // offscreen canvas — рисуем чистые бары, потом двигаем пиксели
    var off  = document.createElement('canvas');
    var oCtx = off.getContext('2d');

    var dst; // ImageData — выделяем один раз

    function resize() {
      var W     = window.innerWidth;
      canvas.width  = W;
      canvas.height = H;
      off.width     = W;
      off.height    = H;
      dst = ctx.createImageData(W, H);
    }
    resize();
    window.addEventListener('resize', resize);

    function draw() {
      var W = canvas.width;

      // 1. Рисуем чистые бары на offscreen (те же параметры что в HTML)
      oCtx.clearRect(0, 0, W, H);
      for (var i = 0; i < N; i++) {
        var pos  = i / (N - 1);
        var dist = Math.abs(pos - 0.5) * 2;
        var barH = (0.30 + 0.70 * Math.pow(dist, 1.3)) * H;
        var op   = (0.25 + 0.10 * Math.sin(t + i * 0.4)).toFixed(3);
        var g    = oCtx.createLinearGradient(0, 0, 0, barH);
        g.addColorStop(0, 'rgba(145,71,255,' + op + ')');
        g.addColorStop(1, 'rgba(145,71,255,0)');
        oCtx.fillStyle = g;
        oCtx.fillRect((i / N) * W, 0, W / N + 0.5, barH);
      }

      // 2. Предвычисляем displacement по X и Y отдельно — O(W+H) вместо O(W*H)
      var xD = new Float32Array(W);
      var yD = new Float32Array(H);
      for (var x = 0; x < W; x++) {
        xD[x] = Math.sin(x * 0.016 + t * 0.45) * 9 +
                Math.sin(x * 0.046 + t * 0.80) * 5;
      }
      for (var y = 0; y < H; y++) {
        yD[y] = Math.sin(y * 0.022 + t * 0.55) * 10 +
                Math.sin(y * 0.055 + t * 1.00) * 5  +
                Math.sin(y * 0.12  + t * 1.60) * 2;
      }

      // 3. Pixel displacement — двигаем пиксели как feDisplacementMap scale=14
      var src = oCtx.getImageData(0, 0, W, H);
      var sd  = src.data;
      var dd  = dst.data;

      for (var py = 0; py < H; py++) {
        for (var px = 0; px < W; px++) {
          var sx = (px + xD[px] + 0.5) | 0;
          var sy = (py + yD[py] + 0.5) | 0;
          if (sx < 0) sx = 0; else if (sx >= W) sx = W - 1;
          if (sy < 0) sy = 0; else if (sy >= H) sy = H - 1;
          var si = (sy * W + sx) << 2;
          var di = (py * W + px) << 2;
          dd[di]     = sd[si];
          dd[di + 1] = sd[si + 1];
          dd[di + 2] = sd[si + 2];
          dd[di + 3] = sd[si + 3];
        }
      }
      ctx.putImageData(dst, 0, 0);

      t += 0.013;
      requestAnimationFrame(draw);
    }
    draw();
  })();
</script>

<script>
  (function () {
    var steps   = document.querySelectorAll('.sl-step');
    var screens = document.querySelectorAll('#sl-screens .sl-screen');
    var navItems = document.querySelectorAll('#sl-screens .sl-nav-item');
    var current = 0;

    var stepData = [
      { label: '01 / 04', title: 'Get your challenge', subtitle: 'One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.' },
      { label: '02 / 04', title: 'Stream & upload', subtitle: 'Go live, do your thing, then screenshot your stats. The AI reads the numbers — you don\'t type anything.' },
      { label: '03 / 04', title: 'See what worked', subtitle: 'Not "stream more consistently." The AI tells you what broke this stream, what worked, and what\'s next.' },
      { label: '04 / 04', title: 'Track your journey', subtitle: 'See where you started, where you are, and what\'s ahead. Levels, streaks, XP — your whole arc in one place.' },
    ];
    var isMobile = function() { return window.innerWidth < 1024; };

    var elLabel    = document.getElementById('sl-label');
    var elTitle    = document.getElementById('sl-title');
    var elSubtitle = document.getElementById('sl-subtitle');

    function goTo(index) {
      if (index === current && screens[index].style.display === 'flex') return;
      current = index;

      // Update steps
      steps.forEach(function (s, i) {
        s.classList.toggle('sl-step--active', i === index);
      });

      // Update header on mobile
      if (isMobile() && stepData[index]) {
        elLabel.textContent    = stepData[index].label;
        elTitle.textContent    = stepData[index].title;
        elSubtitle.textContent = stepData[index].subtitle;
      }

      // Update nav highlights in ALL nav bars (4 items per bar × 4 screens)
      navItems.forEach(function (nav) {
        var parent = nav.parentElement;
        var siblings = Array.prototype.slice.call(parent.querySelectorAll('.sl-nav-item'));
        var pos = siblings.indexOf(nav);
        var icon = nav.querySelector('svg');
        var label = nav.querySelector('span');
        var isActive = pos === index;
        if (icon) icon.setAttribute('stroke', isActive ? '#7C3AED' : '#4A4A6A');
        if (label) {
          label.style.color = isActive ? '#7C3AED' : '#4A4A6A';
          label.style.fontWeight = isActive ? '600' : '400';
        }
      });

      // Animate screen transition
      screens.forEach(function (s, i) {
        if (i === index) {
          s.style.display = 'flex';
          s.classList.add('sl-screen--entering');
          s.classList.remove('sl-screen--visible');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              s.classList.remove('sl-screen--entering');
              s.classList.add('sl-screen--visible');
            });
          });
        } else {
          s.style.display = 'none';
          s.classList.remove('sl-screen--visible', 'sl-screen--entering');
        }
      });
    }

    // Steps click
    steps.forEach(function (step, i) {
      step.addEventListener('click', function () { goTo(i); });
    });

    // Phone nav click — use position within parent (0-3), not global index
    navItems.forEach(function (nav) {
      nav.style.cursor = 'pointer';
      nav.addEventListener('click', function (e) {
        e.stopPropagation();
        var parent = nav.parentElement;
        var siblings = parent.querySelectorAll('.sl-nav-item');
        var idx = Array.prototype.indexOf.call(siblings, nav);
        if (idx >= 0 && idx < screens.length) goTo(idx);
      });
    });
  })();
</script>

