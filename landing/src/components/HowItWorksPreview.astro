  .sl-step__icon {
    width: 18px;
    height: 18px;
    color: var(--sl-purple);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__icon { opacity: 1; }

  .sl-step__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--sl-text);
