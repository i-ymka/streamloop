  @media (min-width: 768px) {
    .sl-header { margin-bottom: 64px; }
  }
  .sl-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sl-purple);
    margin: 0 0 12px;
  }
  .sl-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--sl-text);
    margin: 0 0 16px;
    line-height: 1.15;
