  }
  .sl-repeat-cta__btn {
    padding: 12px 24px;
    border-radius: 12px;
    background: #9147ff;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .sl-repeat-cta__btn:hover { opacity: 0.9; }

  /* ── Blur bar ── */
  #sl-screens .sl-screen::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 36px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 6, 20, 0.6);
    pointer-events: none;
  }

</style>

<script>
  // iOS: CSS filter:url on HTML broken (WebKit bug #261806) — show clean mirror
  (function () {
    var isIOS = /iPhone|iPad|iPod/.test(navigator.userAgent);
    if (!isIOS) return;

    // 1. Remove broken CSS filter
    var mirror = document.getElementById('sl-bars-html');
    if (mirror) mirror.style.filter = 'none';

    // 2. Discord-style glass on phone wrap
    // Key: top-edge highlight = light reflection on glass. Glow behind = something to blur.
    var phoneWrap = document.querySelector('.sl-phone-wrap');
    if (phoneWrap) {
      // Purple glow behind phone so blur has color to show
      var glow = document.createElement('div');
      glow.style.cssText = [
        'position:absolute',
        'inset:-40px -60px',
        'background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(145,71,255,0.35) 0%,transparent 70%)',
        'pointer-events:none',
        'z-index:0',
        'border-radius:50%',
      ].join(';');
      phoneWrap.style.position = 'relative';
      phoneWrap.insertBefore(glow, phoneWrap.firstChild);

      phoneWrap.style.cssText += [
        'background:rgba(12,9,28,0.5)',
        '-webkit-backdrop-filter:blur(16px) saturate(160%)',
        'backdrop-filter:blur(16px) saturate(160%)',
        // Top highlight = Discord glass signature
        'box-shadow:inset 0 1px 0 rgba(255,255,255,0.12),inset 0 -1px 0 rgba(145,71,255,0.08),0 8px 32px rgba(0,0,0,0.4)',
        'border-radius:32px',
        'padding:20px 12px',
      ].join(';');
    }

    // 3. Gyroscope 3D parallax — text/phone float above background
    // Foreground elements move more = depth illusion even on solid background
    if (!window.DeviceOrientationEvent) return;

    var section = document.getElementById('how-it-works');
    var phoneEl = document.querySelector('.sl-phone-wrap');
    var header  = document.querySelector('.sl-header');

    function handleOrientation(e) {
      var gamma = e.gamma || 0; // left-right: -90 to 90
      var beta  = (e.beta || 0) - 30; // normalise: 30° = natural hold

      gamma = Math.max(-25, Math.min(25, gamma));
      beta  = Math.max(-20, Math.min(20, beta));

      // Phone (foreground) moves most
      if (phoneEl) phoneEl.style.transform = 'translateX(' + (gamma * 0.6) + 'px) translateY(' + (beta * 0.3) + 'px)';
      // Header text moves less
      if (header)  header.style.transform  = 'translateX(' + (gamma * 0.25) + 'px) translateY(' + (beta * 0.12) + 'px)';
      // Mirror (background) barely moves
      if (mirror)  mirror.style.transform  = 'translateX(' + (gamma * 0.08) + 'px)';
    }

    // iOS 13+ requires permission for DeviceOrientation
    if (typeof DeviceOrientationEvent.requestPermission === 'function') {
      // Request on first user interaction
      document.addEventListener('touchstart', function askPermission() {
        DeviceOrientationEvent.requestPermission()
          .then(function(state) {
            if (state === 'granted') {
              window.addEventListener('deviceorientation', handleOrientation);
            }
          });
        document.removeEventListener('touchstart', askPermission);
      }, { once: true });
    } else {
      window.addEventListener('deviceorientation', handleOrientation);
    }
  })();
</script>

