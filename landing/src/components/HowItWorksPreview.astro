    margin: 0 0 12px;
  }
  .sl-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--sl-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .sl-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    color: var(--sl-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Body: steps + phone ── */
  .sl-body {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 32px;
  }
  @media (min-width: 1024px) {
    .sl-body {
      flex-direction: row;
      align-items: center;
      gap: 64px;
    }
  }

  /* ── Steps ── */
  .sl-steps-hint {
    font-size: 11px;
    color: #6b6b7b;
    margin: 12px 0 0 4px;
    letter-spacing: 0.02em;
  }
  .sl-steps {
    display: none;
  }
  @media (min-width: 1024px) {
    .sl-steps {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
    }
  }

  .sl-step {
    display: flex;
    gap: 20px;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid hsl(258 35% 16%);
    background: hsl(258 40% 7%);
    cursor: pointer;
    text-align: left;
    transition: background 200ms ease, border-color 200ms ease;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .sl-step { padding: 20px; border-radius: 16px; }
  }
  .sl-step:hover {
    background: hsl(263 69% 56% / 0.08);
    border-color: hsl(263 69% 56% / 0.25);
  }
  .sl-step--active {
    background: var(--sl-purple-dim);
    border-color: hsl(263 69% 56% / 0.4);
  }

  .sl-step__num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1px;
    color: var(--sl-purple);
    opacity: 0.45;
    flex-shrink: 0;
    padding-top: 2px;
    min-width: 24px;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__num { opacity: 1; }

  .sl-step__content { flex: 1; min-width: 0; }

  .sl-step__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0;
  }
  @media (min-width: 1024px) {
