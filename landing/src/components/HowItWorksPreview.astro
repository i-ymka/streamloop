---
// HowItWorksPreview — merged HowItWorks + AppPreview
// Design: Dark OLED + Purple, Plus Jakarta Sans, 8px grid
// Pattern: App Store Style — interactive steps control phone screens
---

<section id="how-it-works" class="sl-section" style="position:relative;overflow:visible;">

  <!-- CSS glow behind canvas — matches Hero's radial glow at meeting point -->
  <div class="absolute left-0 right-0 pointer-events-none" aria-hidden="true"
    style="top:0;height:256px;z-index:0;background:radial-gradient(ellipse 70% 50% at 50% 20%,rgba(145,71,255,0.18) 0%,transparent 70%);"></div>

  <!-- Mirror bars: exact copy of Hero bars, flipped vertically + horizontally -->
  <div class="absolute left-0 right-0 pointer-events-none" aria-hidden="true"
    style="top:0;height:256px;display:flex;align-items:flex-end;transform:scaleY(-1);z-index:1;">
    {Array.from({length: 20}).map((_, i) => {
      const pos = i / 19;
      const dist = Math.abs(pos - 0.5) * 2;
      const h = 30 + 70 * Math.pow(dist, 1.3);
      const delay = (i * 0.08).toFixed(2);
      return (
        <div style={`flex:1;height:${h}%;background:linear-gradient(to top,#9147ff,transparent);opacity:0.35;animation:pulseBar 2s ease-in-out ${delay}s infinite alternate;`}></div>
      );
    })}
  </div>

  <div class="sl-container" style="position:relative;z-index:2;">

    <!-- Header -->
    <div class="sl-header">
      <p class="sl-label">The Loop</p>
      <h2 class="sl-title">Four steps. Every week. Forever.</h2>
      <p class="sl-subtitle">No courses. No fluff. One challenge, one stream, one honest verdict — then repeat.</p>
    </div>

    <!-- Body: steps + phone -->
    <div class="sl-body">

      <!-- Steps (left on desktop, top on mobile) -->
      <div class="sl-steps">

        <button class="sl-step sl-step--active" data-screen="0">
          <div class="sl-step__num">01</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
              <h3 class="sl-step__title">Get your weekly challenge</h3>
            </div>
            <p class="sl-step__desc">One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.</p>
            <ul class="sl-step__bullets">
              <li>Personalised to where you actually are</li>
              <li>Based on your weak spots, not generic advice</li>
              <li>Takes 5 seconds to read, one stream to do</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="1">
          <div class="sl-step__num">02</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
              </svg>
              <h3 class="sl-step__title">Go live and stream</h3>
            </div>
            <p class="sl-step__desc">Do your thing. StreamLoop doesn't interrupt — it just waits. No plugins, no API keys, no setup.</p>
            <ul class="sl-step__bullets">
              <li>Twitch, YouTube, Kick, TikTok — any platform</li>
              <li>Stream exactly how you always do</li>
              <li>Zero overhead, zero interruptions</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="2">
          <div class="sl-step__num">03</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
              </svg>
              <h3 class="sl-step__title">Upload your analytics</h3>
            </div>
            <p class="sl-step__desc">Screenshot your stats page. Drop it in. The AI reads the numbers — you don't have to type anything.</p>
            <ul class="sl-step__bullets">
              <li>Just a screenshot — no API, no OAuth</li>
              <li>Works with any platform's analytics page</li>
              <li>Done in under 30 seconds</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="3">
          <div class="sl-step__num">04</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
              <h3 class="sl-step__title">See exactly what to fix</h3>
            </div>
            <p class="sl-step__desc">Not "stream more consistently." The AI tells you what broke this stream, what worked, and what the next challenge is.</p>
            <ul class="sl-step__bullets">
              <li>Specific to your numbers, not generic tips</li>
              <li>See your level progress and streak</li>
              <li>Next challenge unlocks automatically</li>
            </ul>
          </div>
        </button>

      </div>

      <!-- Phone mockup (right on desktop, bottom on mobile) -->
      <div class="sl-phone-wrap">
        <div class="sl-phone-frame">
          <iphone-16-max mode="dark">
            <div id="sl-screens" style="width:100%;height:100%;position:relative;overflow:hidden;background:#080614;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;">

              <!-- ── Screen 0: Home ── -->
              <div class="sl-screen" data-screen="0" style="position:absolute;inset:0;display:flex;flex-direction:column;background:#080614;">
                <div style="flex:1;overflow-y:auto;padding:36px 14px 10px;display:flex;flex-direction:column;gap:10px;">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                    <div>
                      <h2 style="font-size:20px;font-weight:700;color:#F1F5F9;margin:0;">Hey, Marcus 👋</h2>
                      <p style="font-size:11px;color:#64748B;margin:3px 0 0;">Week 4 of your journey</p>
                    </div>
                    <div style="width:32px;height:32px;border-radius:50%;background:#7C3AED;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                      <span style="font-size:13px;font-weight:700;color:white;">M</span>
                    </div>
                  </div>
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                    <div style="background:#1C1208;border-radius:12px;padding:12px;display:flex;flex-direction:column;gap:4px;">
                      <span style="font-size:18px;">🔥</span>
                      <p style="font-size:22px;font-weight:800;color:#F1F5F9;margin:0;line-height:1;">4</p>
