                      <p style="font-size:9px;font-weight:700;color:#7C3AED;margin:0;">62%</p>
                    </div>
                    <div style="height:4px;background:#2A2040;border-radius:2px;overflow:hidden;">
                      <div style="width:62%;height:100%;background:#7C3AED;border-radius:2px;"></div>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-top:5px;">
                      <p style="font-size:10px;color:#A78BFA;margin:0;">Someone's watching</p>
                      <p style="font-size:10px;color:#4A4468;margin:0;">Small circle →</p>
                    </div>
                  </div>
                  <p style="font-size:9px;font-weight:700;letter-spacing:1px;color:#64748B;margin:0;">THIS WEEK'S CHALLENGE</p>
                  <div style="background:#141028;border-radius:12px;padding:12px;display:flex;flex-direction:column;gap:8px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <span style="background:#7C3AED;color:white;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;">ACTIVE</span>
                      <span style="font-size:10px;color:#64748B;">WEEK 4</span>
                    </div>
                    <p style="font-size:13px;font-weight:700;color:#F1F5F9;line-height:1.35;margin:0;">Go live for 60 minutes without checking your viewer count</p>
                    <p style="font-size:11px;color:#94A3B8;line-height:1.5;margin:0;">Anxiety-checking your numbers mid-stream tanks your energy. Your audience can feel it.</p>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                      <span style="font-size:10px;color:#64748B;">⏱ Ends Sunday</span>
                      <span style="font-size:10px;font-weight:700;color:#F59E0B;">+150 XP</span>
                    </div>
                    <div style="background:#7C3AED;border-radius:8px;padding:10px;text-align:center;">
                      <span style="font-size:12px;font-weight:700;color:white;">Mark as Complete</span>
                    </div>
                  </div>
                </div>
                <div style="flex-shrink:0;height:54px;background:#06040F;border-top:1px solid #2A2040;display:flex;align-items:center;">
                  <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;"><svg width="16" height="16" fill="none" stroke="#7C3AED" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12L12 3l9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg><span style="font-size:9px;color:#7C3AED;font-weight:600;">Home</span></div>
                  <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;"><svg width="16" height="16" fill="none" stroke="#4A4A6A" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg><span style="font-size:9px;color:#4A4A6A;">Upload</span></div>
                  <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;"><svg width="16" height="16" fill="none" stroke="#4A4A6A" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><span style="font-size:9px;color:#4A4A6A;">Analysis</span></div>
                  <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;"><svg width="16" height="16" fill="none" stroke="#4A4A6A" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg><span style="font-size:9px;color:#4A4A6A;">Progress</span></div>
                </div>
              </div>

              <!-- ── Screen 1: Upload ── -->
