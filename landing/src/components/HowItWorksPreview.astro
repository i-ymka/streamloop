<style>
  /* ── Design tokens ── */
  :root {
    --sl-bg: hsl(258 60% 5%);
    --sl-surface: hsl(258 40% 11%);
    --sl-border: hsl(258 35% 18%);
    --sl-purple: hsl(263 69% 56%);
    --sl-purple-dim: hsl(263 69% 56% / 0.12);
    --sl-text: hsl(213 31% 95%);
    --sl-muted: hsl(220 10% 68%);
    --sl-label: hsl(220 10% 43%);
  }

  /* ── Layout ── */
  .sl-section {
    position: relative;
    padding: 96px 24px;
    background: transparent;
    overflow: visible;
  }
  .sl-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .sl-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .sl-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sl-purple);
    margin: 0 0 12px;
  }
  .sl-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--sl-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .sl-subtitle {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 16px;
    color: var(--sl-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Body: steps + phone ── */
  .sl-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }
  @media (min-width: 1024px) {
    .sl-body {
      flex-direction: row;
      align-items: flex-start;
      gap: 64px;
    }
  }

  /* ── Steps ── */
  .sl-steps {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 100%;
    max-width: 520px;
  }
  @media (min-width: 1024px) {
    .sl-steps { flex: 1; }
  }

  .sl-step {
    display: flex;
    gap: 20px;
    padding: 20px;
    border-radius: 16px;
    border: 1px solid hsl(258 35% 16%);
    background: hsl(258 40% 7%);
    cursor: pointer;
    text-align: left;
    transition: background 200ms ease, border-color 200ms ease;
    width: 100%;
  }
  .sl-step:hover {
    background: hsl(263 69% 56% / 0.08);
    border-color: hsl(263 69% 56% / 0.25);
  }
  .sl-step--active {
    background: var(--sl-purple-dim);
    border-color: hsl(263 69% 56% / 0.4);
  }

  .sl-step__num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1px;
    color: var(--sl-purple);
    opacity: 0.45;
    flex-shrink: 0;
    padding-top: 2px;
    min-width: 24px;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__num { opacity: 1; }

  .sl-step__content { flex: 1; min-width: 0; }

  .sl-step__header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .sl-step__icon {
    width: 18px;
    height: 18px;
    color: var(--sl-purple);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 200ms ease;
  }
  .sl-step--active .sl-step__icon { opacity: 1; }

  .sl-step__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--sl-text);
    margin: 0;
    line-height: 1.3;
  }

  .sl-step__desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    color: var(--sl-muted);
    line-height: 1.6;
    margin: 0 0 10px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 250ms ease, opacity 250ms ease, margin 250ms ease;
  }
  .sl-step--active .sl-step__desc {
    max-height: 100px;
    opacity: 1;
  }

  .sl-step__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 250ms ease, opacity 250ms ease;
  }
  .sl-step--active .sl-step__bullets {
    max-height: 120px;
    opacity: 1;
  }
  .sl-step__bullets li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    color: var(--sl-label);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }
  .sl-step__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sl-purple);
    opacity: 0.6;
  }

  /* ── Phone ── */
  .sl-phone-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sl-phone-frame {
    width: 270px;
  }

  /* ── Scrollbar hide ── */
  #sl-screens * {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #sl-screens *::-webkit-scrollbar { display: none; }

  /* ── Blur bar ── */
  #sl-screens .sl-screen::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 36px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 6, 20, 0.6);
    pointer-events: none;
  }
</style>

<script>
  (function () {
    var steps   = document.querySelectorAll('.sl-step');
    var screens = document.querySelectorAll('#sl-screens .sl-screen');

    function goTo(index) {
      steps.forEach(function (s, i) {
        s.classList.toggle('sl-step--active', i === index);
      });
      screens.forEach(function (s, i) {
        s.style.display = i === index ? 'flex' : 'none';
      });
    }

    steps.forEach(function (step, i) {
      step.addEventListener('click', function () { goTo(i); });
    });

    // Step 1 (index 1) has no phone screen — map it to screen 0
    steps[1].addEventListener('click', function () { goTo(0); });
  })();
</script>

