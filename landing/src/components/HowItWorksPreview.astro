---
// HowItWorksPreview — merged HowItWorks + AppPreview
// Design: Dark OLED + Purple, Plus Jakarta Sans, 8px grid
// Pattern: App Store Style — interactive steps control phone screens
---

<section id="how-it-works" class="sl-section" style="position:relative;overflow:hidden;">

  <div class="sl-container" style="position:relative;z-index:3;">

    <!-- Header -->
    <div class="sl-header">
      <p class="sl-label" id="sl-label">The Loop</p>
      <h2 class="sl-title" id="sl-title">Four steps. Every stream.</h2>
      <p class="sl-subtitle" id="sl-subtitle">No courses. No fluff. One challenge, one stream, one honest verdict — then repeat.</p>
    </div>

    <!-- Body: steps + phone -->
    <div class="sl-body">

      <!-- Steps (left on desktop, top on mobile) -->
      <div class="sl-steps">

        <button class="sl-step sl-step--active" data-screen="0">
          <div class="sl-step__num">01</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
              <h3 class="sl-step__title">Get your challenge</h3>
            </div>
            <p class="sl-step__desc">One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.</p>
            <ul class="sl-step__bullets">
              <li>Personalised to where you actually are</li>
              <li>Based on your weak spots, not generic advice</li>
              <li>Takes 5 seconds to read, one stream to do</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="1">
          <div class="sl-step__num">02</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
              </svg>
              <h3 class="sl-step__title">Stream & upload</h3>
            </div>
            <p class="sl-step__desc">Go live, do your thing, then screenshot your stats. Drop it in — the AI reads the numbers, you don't type anything.</p>
            <ul class="sl-step__bullets">
              <li>Twitch, YouTube, Kick, TikTok — any platform</li>
              <li>Just a screenshot — no API, no OAuth</li>
              <li>Done in under 30 seconds</li>
            </ul>
          </div>
        </button>

        <button class="sl-step" data-screen="2">
          <div class="sl-step__num">03</div>
          <div class="sl-step__content">
            <div class="sl-step__header">
              <svg class="sl-step__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
