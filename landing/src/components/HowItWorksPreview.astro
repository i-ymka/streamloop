    var stepData = [
      { label: '01 / 04', title: 'Get your challenge', subtitle: 'One mission, picked for your exact level. Not a list of tips — a single thing to focus on this stream.' },
      { label: '02 / 04', title: 'Stream & upload', subtitle: 'Go live, do your thing, then screenshot your stats. The AI reads the numbers — you don\'t type anything.' },
      { label: '03 / 04', title: 'See what worked', subtitle: 'Not "stream more consistently." The AI tells you what broke this stream, what worked, and what\'s next.' },
      { label: '04 / 04', title: 'Track your journey', subtitle: 'See where you started, where you are, and what\'s ahead. Levels, streaks, XP — your whole arc in one place.' },
    ];
    var isMobile = function() { return window.innerWidth < 1024; };

    var elLabel    = document.getElementById('sl-label');
    var elTitle    = document.getElementById('sl-title');
    var elSubtitle = document.getElementById('sl-subtitle');

    // Create and position the hint overlay for the next nav slot
    var hintOverlay = null;
    function buildHintOverlay() {
      var el = document.createElement('div');
      el.className = 'sl-nav-hint-overlay';
      el.innerHTML =
        '<span class="hint-label">tap to explore</span>' +
        '<div class="hint-rings">' +
          '<div class="hint-ring"></div>' +
          '<div class="hint-ring"></div>' +
        '</div>';
      return el;
    }

    function updateNavHintOverlay(index) {
      // Remove existing overlay from any screen
      if (hintOverlay && hintOverlay.parentElement) {
        hintOverlay.parentElement.removeChild(hintOverlay);
      }
      if (window.innerWidth >= 1024) return;

      var activeScreen = screens[index];
      if (!activeScreen) return;

      // Next nav index (wraps: after last screen show index 0 hint)
      var nextNavIndex = (index + 1) % 4;

      if (!hintOverlay) hintOverlay = buildHintOverlay();

      /*
       * Position the zero-size anchor at the centre of the hinted nav icon:
       *   horizontal: slot centre = (nextNavIndex + 0.5) / 4 * 100%
       *   vertical:   nav bar mid = 27px from screen bottom
       */
      hintOverlay.style.left = ((nextNavIndex + 0.5) / 4 * 100) + '%';
      hintOverlay.style.bottom = '27px';

      // Append to #sl-screens (has overflow:hidden) not to active screen
      var screensContainer = document.getElementById('sl-screens');
      if (screensContainer) screensContainer.appendChild(hintOverlay);
    }

    function goTo(index) {
      if (index === current && screens[index].style.display === 'flex') return;
      current = index;

      // Update steps
      steps.forEach(function (s, i) {
        s.classList.toggle('sl-step--active', i === index);
      });

      // Update header on mobile
      if (isMobile() && stepData[index]) {
        elLabel.textContent    = stepData[index].label;
        elTitle.textContent    = stepData[index].title;
        elSubtitle.textContent = stepData[index].subtitle;
      }

      // Update nav highlights in ALL nav bars (4 items per bar × 4 screens)
      navItems.forEach(function (nav) {
        var parent = nav.parentElement;
        var siblings = Array.prototype.slice.call(parent.querySelectorAll('.sl-nav-item'));
        var pos = siblings.indexOf(nav);
        var icon = nav.querySelector('svg');
        var label = nav.querySelector('span');
        var isActive = pos === index;
        if (icon) icon.setAttribute('stroke', isActive ? '#7C3AED' : '#4A4A6A');
        if (label) {
          label.style.color = isActive ? '#7C3AED' : '#4A4A6A';
          label.style.fontWeight = isActive ? '600' : '400';
        }
      });

      // Nav hint overlay — mobile only: show ping ring + label above the NEXT nav icon
      updateNavHintOverlay(index);

      // Animate screen transition
      screens.forEach(function (s, i) {
        if (i === index) {
          s.style.display = 'flex';
          s.classList.add('sl-screen--entering');
          s.classList.remove('sl-screen--visible');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              s.classList.remove('sl-screen--entering');
              s.classList.add('sl-screen--visible');
            });
          });
        } else {
          s.style.display = 'none';
          s.classList.remove('sl-screen--visible', 'sl-screen--entering');
        }
      });
    }

    // Steps click
    steps.forEach(function (step, i) {
      step.addEventListener('click', function () { goTo(i); });
    });

    // Phone nav click — use position within parent (0-3), not global index
    navItems.forEach(function (nav) {
      nav.style.cursor = 'pointer';
      nav.addEventListener('click', function (e) {
        e.stopPropagation();
        var parent = nav.parentElement;
        var siblings = parent.querySelectorAll('.sl-nav-item');
        var idx = Array.prototype.indexOf.call(siblings, nav);
        if (idx >= 0 && idx < screens.length) goTo(idx);
      });
    });

    // Init hint on screen 0 (mobile only)
    updateNavHintOverlay(0);
  })();

  // Phone materialise on scroll into view
  (function() {
    var phoneWrap = document.querySelector('.sl-phone-wrap');
    if (!phoneWrap) return;
    var obs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        phoneWrap.classList.add('is-visible');
        obs.disconnect();
      }
    }, { threshold: 0.2 });
    obs.observe(phoneWrap);
  })();

  // Repeat waitlist form
  (function() {
    var SCRIPT_URL2 = 'https://script.google.com/macros/s/AKfycbzfUYcflfSDcnQa04wpyn5-1JpR5uZwYoxZyqvKwcW3-lEgf1rI7pEV59BPEf87oO8S/exec';
    var form2 = document.getElementById('waitlist-form-2');
    var input2 = document.getElementById('email-input-2');
    var error2 = document.getElementById('form-error-2');
    var success2 = document.getElementById('form-success-2');
    if (!form2) return;
    form2.addEventListener('submit', async function(e) {
      e.preventDefault();
      error2.classList.add('hidden');
      var email = input2.value.trim();
      if (!email || !email.includes('@') || !email.includes('.')) {
        error2.classList.remove('hidden');
        return;
      }
      var btn = form2.querySelector('button');
      btn.disabled = true;
      btn.textContent = 'Joining...';
      try {
        await fetch(SCRIPT_URL2, { method: 'POST', mode: 'no-cors', headers: {'Content-Type':'application/json'}, body: JSON.stringify({email}) });
        form2.classList.add('hidden');
        success2.classList.remove('hidden');
      } catch {
        btn.disabled = false;
        btn.textContent = 'Get my first challenge';
        error2.classList.remove('hidden');
        error2.textContent = 'Something went wrong. Try again.';
      }
    });
  })();

  // ── Scroll-until-reach on phone ─────────────────────────────────────────
  // Hover over phone → capture wheel. At scroll boundary → release to page.
  (function () {
    var phoneWrap = document.querySelector('.sl-phone-wrap');
    if (!phoneWrap) return;

    var hovered = false;

    phoneWrap.addEventListener('mouseenter', function () { hovered = true; });
    phoneWrap.addEventListener('mouseleave', function () { hovered = false; });

    window.addEventListener('wheel', function (e) {
      if (!hovered) return;

      // Find scrollable element in active screen
      var activeScreen = document.querySelector('.sl-screen.sl-screen--visible');
      if (!activeScreen) return;

      var scrollable = (function () {
        var node = e.target;
        // Walk up from event target looking for scrollable
        while (node && node !== document.body) {
          var oy = window.getComputedStyle(node).overflowY;
          if ((oy === 'auto' || oy === 'scroll') && node.scrollHeight > node.clientHeight + 1) return node;
          node = node.parentElement;
        }
        // Fallback: first scrollable child of active screen
        var kids = activeScreen.querySelectorAll('*');
        for (var i = 0; i < kids.length; i++) {
          var oy2 = window.getComputedStyle(kids[i]).overflowY;
          if ((oy2 === 'auto' || oy2 === 'scroll') && kids[i].scrollHeight > kids[i].clientHeight + 1) return kids[i];
        }
        return null;
      })();

      if (!scrollable) return;

      var atTop    = scrollable.scrollTop <= 0 && e.deltaY < 0;
      var atBottom = scrollable.scrollTop + scrollable.clientHeight >= scrollable.scrollHeight - 1 && e.deltaY > 0;

      if (atTop || atBottom) return; // release to page

      e.preventDefault();
      scrollable.scrollTop += e.deltaY;

    }, { passive: false });
  })();
</script>

