---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import HowItWorksPreview from '../components/HowItWorksPreview.astro';
import DiscordBlock from '../components/DiscordBlock.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>StreamLoop — You stream. We improve. Repeat.</title>
    <meta name="description" content="The feedback loop every streamer needs but no one built. Get a challenge, stream, upload your stats, see exactly what to improve." />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2LDK6ZPMB1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2LDK6ZPMB1');
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden">

    <!-- SVG filter definitions — global scope for iOS WebKit compatibility -->
    <svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;">
      <defs>
        <filter id="water-ripple" x="-50%" y="-50%" width="200%" height="200%"
                color-interpolation-filters="sRGB">
          <feTurbulence type="turbulence" baseFrequency="0.016 0.046" numOctaves="3" result="noise">
            <animate attributeName="baseFrequency"
              values="0.015 0.044;0.019 0.052;0.015 0.044"
              dur="16s" repeatCount="indefinite"
              calcMode="spline"
              keySplines="0.4 0 0.6 1;0.4 0 0.6 1"/>
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="14"
            xChannelSelector="R" yChannelSelector="G"/>
        </filter>
      </defs>
    </svg>

    <!-- Global ambient canvas — spans entire page, pointer-events:none -->
    <div aria-hidden="true" style="position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;">
      <!-- Blob 1: top-center, Hero area -->
      <div style="position:absolute;top:-15%;left:20%;width:900px;height:900px;border-radius:50%;background:radial-gradient(circle,rgba(145,71,255,0.11) 0%,transparent 65%);animation:blobDrift1 24s ease-in-out infinite;"></div>
      <!-- Blob 2: middle-right, HowItWorks area -->
      <div style="position:absolute;top:38%;right:-18%;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(124,58,237,0.08) 0%,transparent 65%);animation:blobDrift2 30s ease-in-out infinite;"></div>
      <!-- Blob 3: bottom-left, Discord area -->
      <div style="position:absolute;top:72%;left:-12%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(145,71,255,0.07) 0%,transparent 65%);animation:blobDrift3 36s ease-in-out infinite;"></div>
    </div>

    <!-- Page content (above ambient layer) -->
    <div style="position:relative;z-index:1;">
      <Hero />
      <HowItWorksPreview />
      <DiscordBlock />
      <Footer />
    </div>

  </body>
</html>
